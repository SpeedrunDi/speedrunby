# No runtime secrets are required to build or run this site.
# The variables below are used only by optional tooling.

# scripts/check-confidential.mjs — comma-separated list of forbidden terms.
# In CI this comes from a GitHub Actions secret; locally you may keep the
# list in a git-ignored `.forbidden-terms.local` file instead.
FORBIDDEN_TERMS=

# workers/contact (post-launch, optional) — set via `wrangler secret put`,
# never in this repo:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
