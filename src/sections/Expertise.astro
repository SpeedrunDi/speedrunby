---
import { type Locale } from '../i18n/types';
import { t, useTranslations } from '../i18n/utils';
import { expertise } from '../data/expertise';
import SectionHeader from '../components/SectionHeader.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const tr = useTranslations(locale);

const icons: Record<string, string> = {
  'ai-agentic':
    '<circle cx="12" cy="5" r="2.4"/><circle cx="5" cy="18" r="2.4"/><circle cx="19" cy="18" r="2.4"/><path d="M12 7.4v4M12 11.4 6.6 16M12 11.4 17.4 16"/>',
  backend:
    '<ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/>',
  frontend: '<path d="m8 9-3 3 3 3M16 9l3 3-3 3M13 6l-2 12"/>',
};
---

<section
  id="expertise"
  class="border-line cv-section border-t py-20 md:py-28"
  aria-labelledby="expertise-title"
>
  <div class="container-edge">
    <SectionHeader
      eyebrow={tr('expertise.eyebrow')}
      title={tr('expertise.title')}
      id="expertise-title"
    />
    <div class="reveal-group mt-10 grid gap-4 md:grid-cols-3">
      {
        expertise.map((card) => (
          <article
            class:list={[
              'fade-up card hover:bg-surface-2 p-6 transition-[transform,border-color,background-color] duration-200 hover:-translate-y-1',
              card.lead && 'border-clay-ring',
            ]}
          >
            <div class="bg-clay-tint text-clay border-clay-ring mb-4 grid h-10.5 w-10.5 place-items-center rounded-xl border">
              <svg
                class="h-5.5 w-5.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[card.id]}
              />
            </div>
            <h3
              class="text-ink text-lg font-semibold"
              style="font-family: var(--font-display-active);"
            >
              {t(card.title, locale)}
            </h3>
            <p class="text-ink-2 mt-2 text-sm leading-relaxed">{t(card.body, locale)}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {card.hints.map((h) => (
                <span class="chip !text-[0.68rem]">{h}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
