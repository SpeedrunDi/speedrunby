---
import { type Locale } from '../i18n/types';
import { useTranslations } from '../i18n/utils';
import { profile } from '../data/profile';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const tr = useTranslations(locale);
---

<section
  id="contact"
  class="border-line relative overflow-hidden border-t py-24 md:py-32"
  aria-labelledby="contact-title"
>
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(70%_130%_at_50%_0%,var(--su-clay-tint),transparent_60%)]"
    aria-hidden="true"
  >
  </div>
  <div class="container-edge reveal-group text-center">
    <p class="eyebrow fade-up justify-center">{tr('contact.eyebrow')}</p>
    <h2
      id="contact-title"
      class="text-ink fade-up mx-auto mt-5 max-w-[20ch]"
      style="font-size: var(--text-display); line-height: 1.03; letter-spacing: -0.025em;"
    >
      {tr('contact.title')}
    </h2>
    <p class="text-ink-2 fade-up mx-auto mt-5 max-w-[48ch]" style="font-size: var(--text-lead);">
      {tr('contact.lede')}
    </p>
    <div class="fade-up mt-9 flex flex-wrap justify-center gap-3">
      <button
        type="button"
        class="btn btn-primary relative"
        data-copy-email={profile.email}
        data-magnet
      >
        <span
          class="copy-toast bg-ink text-bg pointer-events-none absolute -top-9 left-1/2 -translate-x-1/2 rounded-md px-2.5 py-1 font-mono text-[0.68rem] whitespace-nowrap opacity-0 transition-opacity"
          aria-hidden="true"
        >
          {tr('contact.copied')}
        </span>
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.9"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
        {profile.email}
      </button>
      <a
        class="btn btn-ghost"
        href={profile.socials.telegram}
        target="_blank"
        rel="noopener"
        data-magnet
      >
        Telegram
      </a>
      <a
        class="btn btn-ghost"
        href={profile.socials.github}
        target="_blank"
        rel="noopener"
        data-magnet
      >
        GitHub
      </a>
      <a
        class="btn btn-ghost"
        href={profile.socials.linkedin}
        target="_blank"
        rel="noopener"
        data-magnet
      >
        LinkedIn
      </a>
    </div>
    <p class="sr-only" role="status" aria-live="polite" data-copy-status></p>
  </div>
</section>
