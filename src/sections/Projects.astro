---
import { type Locale } from '../i18n/types';
import { useTranslations } from '../i18n/utils';
import { projects } from '../data/projects';
import SectionHeader from '../components/SectionHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const tr = useTranslations(locale);

const flagships = projects.filter((p) => p.flagship);
const others = projects.filter((p) => !p.flagship);
---

<section
  id="work"
  class="border-line cv-section border-t py-20 md:py-28"
  aria-labelledby="work-title"
>
  <div class="container-edge">
    <SectionHeader eyebrow={tr('work.eyebrow')} title={tr('work.title')} id="work-title" />

    <div class="reveal-group mt-10 grid gap-4 md:grid-cols-2">
      {flagships.map((p) => <ProjectCard locale={locale} project={p} />)}
    </div>
    <div class="reveal-group mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {others.map((p) => <ProjectCard locale={locale} project={p} />)}
    </div>
  </div>
</section>
