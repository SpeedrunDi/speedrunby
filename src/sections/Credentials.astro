---
import { type Locale } from '../i18n/types';
import { t, useTranslations } from '../i18n/utils';
import { credentials, LINKEDIN_CERTS_URL } from '../data/credentials';
import SectionHeader from '../components/SectionHeader.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const tr = useTranslations(locale);

const featured = credentials.find((c) => c.featured)!;
const rest = credentials.filter((c) => !c.featured);
---

<section
  id="credentials"
  class="border-line cv-section border-t py-20 md:py-28"
  aria-labelledby="credentials-title"
>
  <div class="container-edge">
    <SectionHeader
      eyebrow={tr('credentials.eyebrow')}
      title={tr('credentials.title')}
      lede={tr('credentials.lede')}
      id="credentials-title"
    />

    <!-- featured: Claude Certified Architect -->
    <article
      class="reveal-group border-clay-ring mt-10 grid items-center gap-8 rounded-3xl border bg-[radial-gradient(80%_140%_at_0%_0%,var(--su-clay-tint),transparent_60%)] p-7 shadow-2xl md:grid-cols-[auto_1fr] md:p-10"
      style="background-color: var(--su-surface);"
    >
      <div class="fade-up text-center">
        <img
          src="/badges/claude-architect.webp"
          alt="Claude Certified Architect – Foundations badge"
          width="340"
          height="340"
          loading="lazy"
          decoding="async"
          class="mx-auto h-40 w-40 drop-shadow-2xl md:h-48 md:w-48"
          data-tilt
        />
        <a
          href={featured.verifyUrl}
          target="_blank"
          rel="noopener"
          class="text-clay border-clay-ring hover:text-clay-bright mt-4 inline-flex items-center gap-1.5 border-b pb-0.5 font-mono text-[0.7rem] tracking-wider uppercase"
        >
          {tr('badge.verify')}
          <svg
            class="h-3 w-3"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="M7 17 17 7M8 7h9v9"></path></svg
          >
        </a>
      </div>

      <div>
        <p
          class="fade-up text-clay flex items-center gap-2 font-mono text-[0.7rem] tracking-[0.14em] uppercase"
        >
          <span class="bg-clay inline-block h-1.5 w-1.5 rounded-full" aria-hidden="true"></span>
          Anthropic · {t(featured.kind!, locale)}
        </p>
        <h3
          class="fade-up text-ink mt-3"
          style="font-family: var(--font-display-active); font-size: clamp(1.4rem, 1.1rem + 1.3vw, 2rem); line-height: 1.1;"
        >
          {featured.name}
        </h3>
        <p class="fade-up text-ink-2 mt-3 max-w-[60ch]">{t(featured.description!, locale)}</p>
        <div class="fade-up mt-4 flex flex-wrap gap-2">
          <span class="pill"
            ><b class="text-ink font-medium">{tr('credentials.issued')}</b>
            {t(featured.issued!, locale)}</span
          >
          <span class="pill"
            ><b class="text-ink font-medium">{tr('credentials.validTo')}</b>
            {t(featured.validTo!, locale)}</span
          >
          <span class="pill"><b class="text-ink font-medium">ID</b> {featured.accreditationId}</span
          >
        </div>
        <p
          class="fade-up text-ink-3 mt-5 mb-2 font-mono text-[0.66rem] tracking-[0.14em] uppercase"
        >
          {tr('credentials.skills')}
        </p>
        <div class="fade-up flex flex-wrap gap-1.5">
          {
            featured.skills!.map((s) => (
              <span class="bg-clay-tint border-clay-ring text-ink rounded-md border px-2 py-1 font-mono text-[0.7rem]">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </article>

    <!-- remaining credentials -->
    <div class="reveal-group mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
      {
        rest.map((c) => (
          <a
            href={c.verifyUrl ?? LINKEDIN_CERTS_URL}
            target="_blank"
            rel="noopener"
            class="fade-up card hover:border-line-strong hover:bg-surface-2 block p-4.5 transition-[transform,border-color,background-color] duration-200 hover:-translate-y-0.5"
          >
            <p class="text-clay font-mono text-[0.62rem] tracking-[0.13em] uppercase">
              {c.issuer} · {c.year}
            </p>
            <h4
              class="text-ink mt-2 text-[0.95rem] leading-snug font-semibold"
              style="font-family: var(--font-display-active);"
            >
              {c.name}
            </h4>
            {c.accreditationId ? (
              <p class="text-ink-3 mt-2 font-mono text-[0.65rem] break-all">
                ID · {c.accreditationId}
              </p>
            ) : c.kind ? (
              <p class="text-ink-3 mt-2 text-xs">{t(c.kind, locale)}</p>
            ) : null}
          </a>
        ))
      }
    </div>

    <p class="reveal-group text-ink-3 mt-6 flex items-center gap-2 text-sm">
      <svg
        class="text-clay h-4 w-4 flex-none"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M9 12l2 2 4-4"></path>
        <circle cx="12" cy="12" r="9"></circle>
      </svg>
      <span class="fade-up">
        {tr('credentials.note').split(' · ')[0]} ·
        <a
          href={LINKEDIN_CERTS_URL}
          target="_blank"
          rel="noopener"
          class="text-clay border-clay-ring hover:text-clay-bright border-b"
        >
          {tr('credentials.note').split(' · ')[1]}
        </a>
      </span>
    </p>
  </div>
</section>
