---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const locale = 'en' as const;
const t = useTranslations(locale);
---

<Layout locale={locale} title={t('site.title')} description={t('site.description')}>
  <main id="main" class="container-edge flex min-h-svh flex-col items-start justify-center gap-4">
    <p class="eyebrow">Verified by Anthropic</p>
    <h1 class="text-ink" style="font-size: var(--text-hero); line-height: 0.98;">
      Amankeldi<br /><span class="text-clay">Kydyraliev</span>
    </h1>
    <p class="text-ink-2 max-w-[52ch]" style="font-size: var(--text-lead);">
      {t('placeholder.lede')}
    </p>
  </main>
</Layout>
