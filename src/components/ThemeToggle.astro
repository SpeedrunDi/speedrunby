---
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  class="border-line-strong text-ink-2 hover:text-ink hover:border-clay-ring inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg border transition-colors"
  aria-label={label}
  aria-pressed="false"
>
  <svg
    class="icon-sun hidden h-4 w-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
    ></path>
  </svg>
  <svg
    class="icon-moon h-4 w-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

<style>
  /* dark shows sun (switch to light), light shows moon */
  :global(html:not([data-theme='light'])) .icon-sun {
    display: block;
  }
  :global(html:not([data-theme='light'])) .icon-moon {
    display: none;
  }
  :global(html[data-theme='light']) .icon-sun {
    display: none;
  }
  :global(html[data-theme='light']) .icon-moon {
    display: block;
  }
</style>
